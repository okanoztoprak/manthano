# Kopieer dit bestand naar .env en vul de waarden in

# Server
PORT=3000
NODE_ENV=development
BASE_URL=https://manthano.nl

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=verander_dit_wachtwoord

# Mollie betalingen
# Haal je API key op via https://my.mollie.com/dashboard/developers/api-keys
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# E-mail (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=simone@manthano.nl
SMTP_PASS=jouw_app_wachtwoord
EMAIL_FROM="Simone – Manthano <simone@manthano.nl>"

# Sessie beveiliging
SESSION_SECRET=verander_dit_naar_een_lange_willekeurige_string
